{
  "name": "talemo-capacitor",
  "version": "1.0.0",
  "description": "CapacitorJS configuration for Talemo PWA",
  "main": "index.js",
  "scripts": {
    "init": "npm install && npx cap init Talemo com.talemo.app --web-dir=../static",
    "add-android": "npx cap add android",
    "add-ios": "npx cap add ios",
    "copy": "npx cap copy",
    "sync": "npx cap sync",
    "open-android": "npx cap open android",
    "open-ios": "npx cap open ios",
    "build-android": "cd android && ./gradlew assembleDebug",
    "build-ios": "cd ios && xcodebuild -workspace App/App.xcworkspace -scheme App -configuration Debug build"
  },
  "dependencies": {
    "@capacitor/android": "^5.0.0",
    "@capacitor/cli": "^5.0.0",
    "@capacitor/core": "^5.0.0",
    "@capacitor/ios": "^5.0.0"
  },
  "devDependencies": {},
  "author": "Talemo Team",
  "license": "UNLICENSED",
  "private": true
}